<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".sixweekcourse">

    <!--navigation bar-->
    <LinearLayout
        android:id="@+id/topBar"
        android:orientation="horizontal"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:padding="12dp"
        android:gravity="center_vertical"
        android:weightSum="5"

        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/image"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:scaleType="fitCenter"
            android:adjustViewBounds="true"
            android:layout_marginEnd="12dp"
            android:src="@drawable/etn_logo" />


        <TextView
            android:id="@+id/home"
            android:text="HOME"
            android:textColor="@color/text_hover"
            android:clickable="true"
            android:focusable="true"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:textSize="12sp"/>


        <TextView
            android:id="@+id/contact"
            android:text="CONTACT"
            android:textColor="@color/text_hover"
            android:clickable="true"
            android:focusable="true"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:textSize="12sp"/>


        <TextView
            android:id="@+id/calculate_fees"
            android:text="CALCULATE FEES"
            android:textColor="@color/text_hover"
            android:clickable="true"
            android:focusable="true"

            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:textSize="12sp"/>

        <TextView
            android:id="@+id/six_week_course"
            android:text="SIX      WEEK"
            android:textColor="@color/text_hover"
            android:clickable="true"
            android:focusable="true"

            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:textSize="12sp"/>

        <TextView
            android:id="@+id/six_month_course"
            android:text="SIX MONTH"
            android:textColor="@color/text_hover"
            android:clickable="true"
            android:focusable="true"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:textSize="12sp"/>

    </LinearLayout>


    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"

        app:layout_constraintTop_toBottomOf="@+id/topBar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">



       <LinearLayout
           android:layout_width="match_parent"
           android:layout_height="wrap_content"
           android:padding="20dp"
           android:gravity="center_horizontal"
           android:orientation="vertical">

           <!--Cont1 Child Minding-->

           <com.google.android.material.card.MaterialCardView
               android:id="@+id/card1"
               android:layout_width="match_parent"
               android:layout_height="wrap_content"
               android:layout_marginTop="12dp"
               app:cardCornerRadius="12dp"
               app:cardElevation="4dp">

               <LinearLayout
                   android:layout_width="match_parent"
                   android:layout_height="wrap_content"
                   android:layout_marginTop="8dp"
                   android:padding="12dp"
                   android:orientation="vertical">

                   <TextView
                       android:layout_height="wrap_content"
                       android:layout_width="match_parent"
                       android:text="Child Minding"
                       android:textStyle="bold"
                       android:textColor="#1A6B1A"
                       android:textSize="20sp"/>


               <LinearLayout
                   android:layout_width="match_parent"
                   android:layout_height="wrap_content"
                   android:layout_marginTop="8dp"
                   android:gravity="center_vertical"
                   android:orientation="horizontal">

                   <ImageView
                       android:id="@+id/image1"
                       android:layout_width="100dp"
                       android:layout_height="100dp"
                       android:scaleType="centerCrop"
                       android:src="@drawable/childminding" />

                   <TextView
                       android:layout_height="wrap_content"
                       android:layout_width="0dp"
                       android:layout_weight="1"
                       android:textColor="#333333"
                       android:text="The purpose of this course is to provide basic child and baby care. Which includes the needs of new born babies to one year old needs, the needs of toddlers and educational toys"
                       android:layout_marginTop="8dp"/>

               </LinearLayout>

                    <!-- Touch as little as possible the second linear layouts in the card containers otherwise views will become broken-->

                   <LinearLayout
                       android:layout_width="match_parent"
                       android:layout_height="wrap_content"
                       android:orientation="horizontal"
                       android:layout_marginTop="8dp"
                       android:gravity="center_vertical">

                       <TextView
                           android:layout_width="0dp"
                           android:layout_height="wrap_content"
                           android:layout_weight="1"
                           android:textColor="#E2725B"
                           android:text="Price R750"/>

                       <!--Button used to go to the next screen-->

                       <Button
                           android:id="@+id/btn_more_info"
                           android:layout_width="wrap_content"
                           android:layout_height="wrap_content"
                           android:text="More Info"
                           android:backgroundTint="#DAA520"
                           android:textColor="#333333"/>

                   </LinearLayout>

               </LinearLayout>

           </com.google.android.material.card.MaterialCardView>

           <!--Cont2 Cooking-->

           <com.google.android.material.card.MaterialCardView
               android:id="@+id/card2"
               android:layout_width="match_parent"
               android:layout_height="wrap_content"
               android:layout_marginTop="12dp"
               app:cardCornerRadius="12dp"
               app:cardElevation="4dp">

               <LinearLayout
                   android:layout_width="match_parent"
                   android:layout_height="wrap_content"
                   android:padding="12dp"
                   android:orientation="vertical">

                   <TextView
                       android:layout_height="wrap_content"
                       android:layout_width="match_parent"
                       android:text="Cooking"
                       android:textStyle="bold"
                       android:textColor="#1A6B1A"
                       android:textSize="20sp"/>

               <LinearLayout
                   android:layout_width="match_parent"
                   android:layout_height="wrap_content"
                   android:layout_marginTop="8dp"
                   android:gravity="center_vertical"
                   android:orientation="horizontal">

                   <ImageView
                       android:id="@+id/image2"
                       android:layout_width="100dp"
                       android:layout_height="120dp"
                       android:scaleType="centerCrop"
                       android:src="@drawable/cooking" />

                   <TextView
                       android:layout_height="wrap_content"
                       android:layout_width="0dp"
                       android:layout_weight="1"
                       android:textColor="#333333"
                       android:text="The purpose of this course is to prepare and cook nutritious family meals. Which includes the nutritional requirements for a healthy body, the types of protein, carbohydrates and vegtables, planning meals, etc"
                       android:layout_marginTop="8dp"/>

               </LinearLayout>

                   <LinearLayout
                       android:layout_width="match_parent"
                       android:layout_height="wrap_content"
                       android:orientation="horizontal"
                       android:layout_marginTop="8dp"
                       android:gravity="center_vertical">

                       <TextView
                           android:layout_width="0dp"
                           android:layout_height="wrap_content"
                           android:layout_weight="1"
                           android:textColor="#E2725B"
                           android:text="Price R750"/>

                       <Button
                           android:id="@+id/btn_more_info2"
                           android:layout_width="wrap_content"
                           android:layout_height="wrap_content"
                           android:text="More Info"
                           android:backgroundTint="#DAA520"
                           android:textColor="#333333"/>

                   </LinearLayout>

               </LinearLayout>

           </com.google.android.material.card.MaterialCardView>

           <!--Cont3 Garden Maintenance-->

           <com.google.android.material.card.MaterialCardView
               android:id="@+id/card3"
               android:layout_width="match_parent"
               android:layout_height="wrap_content"
               android:layout_marginTop="12dp"
               app:cardCornerRadius="12dp"
               app:cardElevation="4dp">

               <LinearLayout
                   android:layout_width="match_parent"
                   android:layout_height="wrap_content"
                   android:padding="12dp"
                   android:orientation="vertical">

                   <TextView
                       android:layout_height="wrap_content"
                       android:layout_width="match_parent"
                       android:text="Garden Maintenance"
                       android:textStyle="bold"
                       android:textColor="#1A6B1A"
                       android:textSize="20sp"/>

               <LinearLayout
                   android:layout_width="match_parent"
                   android:layout_height="wrap_content"
                   android:layout_marginTop="8dp"
                   android:gravity="center_vertical"
                   android:orientation="horizontal">

                   <ImageView
                       android:id="@+id/image3"
                       android:layout_width="100dp"
                       android:layout_height="120dp"
                       android:scaleType="centerCrop"
                       android:src="@drawable/garden" />

                   <TextView
                       android:layout_height="wrap_content"
                       android:layout_width="0dp"
                       android:layout_weight="1"
                       android:textColor="#333333"
                       android:text="The purpose of this course is to provide the basic knowledge of watering, pruning and planting in a dosmestic garden. Which includes water restrictionss and the watering requirements of indigenous and exotic plants,etc"
                       android:layout_marginTop="8dp"/>

               </LinearLayout>

                   <LinearLayout
                       android:layout_width="match_parent"
                       android:layout_height="wrap_content"
                       android:orientation="horizontal"
                       android:layout_marginTop="8dp"
                       android:gravity="center_vertical">

                       <TextView
                           android:layout_width="0dp"
                           android:layout_height="wrap_content"
                           android:layout_weight="1"
                           android:textColor="#E2725B"
                           android:text="Price R750"/>

                       <Button
                           android:id="@+id/btn_more_info3"
                           android:layout_width="wrap_content"
                           android:layout_height="wrap_content"
                           android:text="More Info"
                           android:backgroundTint="#DAA520"
                           android:textColor="#333333"/>

                   </LinearLayout>

               </LinearLayout>

           </com.google.android.material.card.MaterialCardView>

       </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>